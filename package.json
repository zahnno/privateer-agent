{
  "name": "privateer",
  "version": "0.1.0",
  "description": "Privateer — a provider-agnostic terminal coding agent. Bring your own model (OpenRouter, Anthropic, OpenAI, Ollama).",
  "type": "module",
  "license": "MIT",
  "author": "Patrick (zahnno)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zahnno/privateer-agentic-tui.git"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "tui",
    "terminal",
    "openrouter",
    "anthropic",
    "openai",
    "ollama",
    "ai-sdk",
    "ink"
  ],
  "bin": {
    "privateer": "./bin/privateer.mjs"
  },
  "files": [
    "bin",
    "src",
    "brand",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsx src/main.tsx",
    "dev": "tsx watch src/main.tsx",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 tests/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@openrouter/ai-sdk-provider": "^1.0.0",
    "@types/picomatch": "^4.0.3",
    "ai": "^5.0.0",
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ollama-ai-provider-v2": "^1.2.0",
    "picomatch": "^4.0.4",
    "react": "^18.3.1",
    "tsx": "^4.16.0",
    "zod": "^4.0.16"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
